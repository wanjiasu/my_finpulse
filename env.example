# =================================================================
# FinPulse 项目环境变量配置模板
# 使用方法: 复制此文件为 .env 并填入实际值
# cp env.example .env
# =================================================================

# ===== FastAPI 服务配置 =====
# 应用名称，会显示在 API 文档标题中
APP_NAME=finpulse-fastapi-celery
# 服务监听地址 (Docker 内部通常保持 0.0.0.0)
API_HOST=0.0.0.0
# 服务端口
API_PORT=8000

# ===== Redis 配置 =====
# 用于 Celery 消息代理和结果存储
# 格式: redis://:password@host:port/db
REDIS_URL=redis://redis:6379/0

# ===== Celery 配置 =====
# 任务调度与执行的中间件地址
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ===== PostgreSQL 数据库配置 =====
# 数据库登录用户名
POSTGRES_USER=postgres
# 数据库登录密码
POSTGRES_PASSWORD=postgres
# 数据库名称
POSTGRES_DB=finpulse_db
# 数据库连接字符串 (SQLAlchemy 使用)
POSTGRES_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ===== Tushare 数据源配置 =====
# 从 tushare.pro 个人中心获取的 Token
TUSHARE_TOKEN=
# Tushare API 请求地址
# 1. 官方地址 (推荐): https://api.tushare.pro
# 2. 备用/代理地址: http://101.35.233.113:8020/ (当官方地址访问受限时使用)
TUSHARE_HTTP_URL=https://api.tushare.pro
